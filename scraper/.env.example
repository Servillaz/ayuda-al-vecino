# Copia este archivo como .env y rellena los valores
# NUNCA subas el .env real a GitHub (ya está en .gitignore)

# ID de tu Google Sheet (entre /d/ y /edit en la URL)
SHEET_ID=pega_aqui_el_id_de_tu_sheet

# Credenciales del Service Account de Google Cloud (JSON en una sola línea)
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# API Key de Anthropic (Claude)
# Obtén una en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
